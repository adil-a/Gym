+                  value: /tmp
+                - name: NVIDIA_VISIBLE_DEVICES
+                  value: void
+              resources:
+                requests:
+                  cpu: "2"
+                  memory: 4Gi
+                limits:
+                  cpu: "4"
+                  memory: 8Gi
+              securityContext:
+                allowPrivilegeEscalation: false
+                readOnlyRootFilesystem: true
+                capabilities:
+                  drop:
+                    - ALL
+              volumeMounts:
+                - mountPath: /tmp
+                  name: ray-tmp
+          volumes:
+            - name: ray-tmp
+              emptyDir:
+                sizeLimit: 4Gi
+    - groupName: gym-resources
+      replicas: 1
