+name: Build K8s Container Images
+
+on:
+  push:
+    branches: [main]
+    tags: ['v*']
+    paths:
+      - 'k8s/Dockerfile'
+      - 'k8s/head/Containerfile'
+      - 'k8s/entrypoint.sh'
+      - 'nemo_gym/**'
+      - 'resources_servers/**'
+      - 'responses_api_agents/**'
+      - 'responses_api_models/**'
+      - 'pyproject.toml'
+  pull_request:
+    branches: [main]
+    paths:
+      - 'k8s/Dockerfile'
+      - 'k8s/head/Containerfile'
+      - 'k8s/entrypoint.sh'
+      - 'nemo_gym/**'
+      - 'resources_servers/**'
+      - 'responses_api_agents/**'
+      - 'responses_api_models/**'
+      - 'pyproject.toml'
+
+env:
+  REGISTRY: ghcr.io
+
+jobs:
+  build:
+    runs-on: ubuntu-latest
+    strategy:
+      matrix:
+        include:
+          - target: resources
+            image-suffix: nemo-gym-resources
+            dockerfile: k8s/Dockerfile
+          - target: agent
+            image-suffix: nemo-gym-agent
+            dockerfile: k8s/Dockerfile
+          - target: model
+            image-suffix: nemo-gym-model
+            dockerfile: k8s/Dockerfile
+          - target: head
+            image-suffix: nemo-gym-head
+            dockerfile: k8s/head/Containerfile
+    permissions:
+      contents: read
+      packages: write
+
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+
+      - name: Set up Docker Buildx
+        uses: docker/setup-buildx-action@v3
+
+      - name: Log in to GHCR
+        if: github.event_name != 'pull_request'
+        uses: docker/login-action@v3
+        with:
+          registry: ${{ env.REGISTRY }}
+          username: ${{ github.actor }}
+          password: ${{ secrets.GITHUB_TOKEN }}
+
+      - name: Extract metadata
+        id: meta
+        uses: docker/metadata-action@v5
+        with:
+          images: ${{ env.REGISTRY }}/${{ github.repository }}/${{ matrix.image-suffix }}
+          tags: |
+            type=ref,event=branch
+            type=semver,pattern={{version}}
+            type=semver,pattern={{major}}.{{minor}}
+            type=sha,prefix=
+            type=raw,value=latest,enable={{is_default_branch}}
+
+      - name: Build and push
+        uses: docker/build-push-action@v6
+        with:
+          context: .
+          file: ${{ matrix.dockerfile }}
+          target: ${{ matrix.target }}
+          push: ${{ github.event_name != 'pull_request' }}
+          tags: ${{ steps.meta.outputs.tags }}
+          labels: ${{ steps.meta.outputs.labels }}
+          cache-from: type=gha,scope=${{ matrix.target }}
+          cache-to: type=gha,mode=max,scope=${{ matrix.target }}
