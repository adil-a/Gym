+                  name: http
+                  protocol: TCP
+              resources:
+                requests:
+                  cpu: "500m"
+                  memory: 512Mi
+                limits:
+                  memory: 2Gi
+              startupProbe:
+                httpGet:
+                  path: /docs
+                  port: 9080
+                initialDelaySeconds: 30
+                periodSeconds: 5
+                failureThreshold: 60
+              readinessProbe:
+                httpGet:
+                  path: /docs
+                  port: 9080
+                periodSeconds: 10
+                failureThreshold: 3
+              livenessProbe:
+                httpGet:
+                  path: /docs
