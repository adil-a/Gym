# Example env.yaml for finance_agent_v2. Copy to the repo root as `env.yaml`
# and fill in. NEVER commit a populated env.yaml (it holds secrets).
#
# This is a self-contained Gym environment: run it with two configs — the
# environment config (resources_servers/finance_agent_v2/configs/finance_agent_v2.yaml)
# and a model config (responses_api_models/openai_model/configs/openai_model.yaml
# or .../vllm_model/configs/vllm_model.yaml). env.yaml only provides the model
# endpoints below.
#
# The tool API keys (SEC_API_KEY, TAVILY_API_KEY, TIINGO_API_KEY) are read
# directly from your shell by the environment config (${oc.env:...}), so they do
# NOT belong here — just export them in your shell/bashrc.

# Policy model (OpenAI gpt-5-mini) — also reused for retrieve_information.
# For a self-hosted model, point these at your vLLM endpoint and run with
# vllm_model.yaml instead of openai_model.yaml.
policy_base_url: https://api.openai.com/v1
policy_api_key: ${oc.env:OPENAI_API_KEY}
policy_model_name: gpt-5-mini

# Judge model (OpenAI-compatible or local vLLM) used by /verify (path A scoring).
search_judge_model_base_url: https://api.openai.com/v1
search_judge_model_api_key: ${oc.env:OPENAI_API_KEY}
search_judge_model_name: gpt-5-mini
