Bootstrap: docker
From: python:3.12-bookworm

%labels
    Author NVIDIA NeMo-Gym
    Description GDPVal Apptainer container with all document generation dependencies

%post
    apt-get update && apt-get install -y --no-install-recommends \
        git \
        build-essential \
        gcc \
        g++ \
        cmake \
        pkg-config \
        make \
        coreutils \
        libpango1.0-dev \
        libcairo2-dev \
        libgdk-pixbuf2.0-dev \
        libreoffice-core \
        libreoffice-writer \
        libreoffice-calc \
        libreoffice-impress \
        fonts-dejavu-core \
        tesseract-ocr \
        pandoc \
        poppler-utils \
        ghostscript \
        ffmpeg \
        graphviz \
        curl \
        wget \
        && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir \
        python-docx fpdf2 reportlab weasyprint PyPDF2 beautifulsoup4 \
        seaborn python-pptx markdown2 pdfminer.six openpyxl lxml Pillow \
        numpy scipy pandas matplotlib plotly bokeh \
        scikit-learn scikit-image statsmodels \
        nltk gensim spacy textblob \
        opencv-python-headless \
        sympy h5py \
        networkx pydot graphviz svgwrite \
        shapely geopandas geopy \
        requests httpx aiohttp \
        tqdm tabulate faker \
        pytest

    mkdir -p /workspace

%environment
    export HOME=/root
    export PATH=/usr/local/bin:$PATH
    export DEBIAN_FRONTEND=noninteractive

%runscript
    exec /bin/bash "$@"
